# VK Community settings
VK_COMMUNITY_TOKEN=vk1.a.YOUR_TOKEN_HERE
VK_GROUP_ID=123456789
VK_ADMIN_ID=123456789
VK_WAITERS_CHAT_ID=2000000001

# Cafe info (used in guest messages)
CAFE_ADDRESS=ул. Примерная 1

# PostgreSQL
DB_USER=postgres
DB_PASSWORD=your_strong_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=reservation

# CORS: add your production domain here (comma-separated if multiple)
# Example: CORS_ORIGIN=https://your-domain.ru
CORS_ORIGIN=

# Optional: Sentry error tracking
# SENTRY_DSN=https://...@sentry.io/...

# Optional: app environment (production / development)
APP_ENV=production
